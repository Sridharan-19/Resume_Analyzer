================================================================================
BROWSER CONFIGURATION (Optional)
================================================================================
# Chrome driver path (auto-detected if not set)
# BROWSER_DRIVER_PATH=/path/to/chromedriver

# Browser headless mode (true = no GUI, false = show browser)
BROWSER_HEADLESS=true

================================================================================
APPLICATION SETTINGS
================================================================================
# Max applications per hour (rate limiting)
MAX_APPS_PER_HOUR=10

# Delay between applications (seconds)
DELAY_BETWEEN_APPS=5

# Retry failed applications
MAX_RETRY_ATTEMPTS=3
